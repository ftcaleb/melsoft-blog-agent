# ---------------------------------------------------------------------------
# Melsoft Blog Agent — environment configuration
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Access control: both pages (generator + dashboard) require a Supabase login,
# and the billed /api routes verify that Supabase session server-side. There is
# no separate app password to configure.
# ---------------------------------------------------------------------------

# REQUIRED — Anthropic API key used by research + post generation.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# REQUIRED — Supabase project URL (e.g. https://xxxx.supabase.co).
SUPABASE_URL=your_supabase_project_url_here

# REQUIRED — Supabase SERVICE ROLE key (server-side only; never expose to the
# browser). Used by src/supabaseClient.js for reads/writes and for validating
# the caller's Supabase session token on /api requests.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# OPTIONAL — secret that authenticates the scheduled cron (/api/cron/refresh-topics).
# Vercel injects it as "Authorization: Bearer <CRON_SECRET>" on cron runs.
CRON_SECRET=choose_a_random_string

# OPTIONAL — Discord webhook URL. When set, the Tue/Fri cron posts a notification
# here after it generates fresh topics. Leave unset to disable notifications.
DISCORD_WEBHOOK_URL=

# OPTIONAL — public app URL used in the Discord notification link and in the
# "review this draft" dashboard link sent back by the /generate command.
# Defaults to https://melsoft-blog.vercel.app when unset.
APP_URL=

# ---------------------------------------------------------------------------
# Discord Interactions (slash commands + buttons). These power the
# POST /api/discord/interactions endpoint and the one-time command-registration
# script (scripts/registerDiscordCommands.js). All of the values below are
# already configured locally and in Vercel — listed here only for documentation.
# ---------------------------------------------------------------------------

# Discord application (client) ID — used to register commands and to build the
# interaction followup webhook URL.
DISCORD_APPLICATION_ID=

# Discord application PUBLIC KEY — used to verify the Ed25519 signature on every
# incoming interaction request. Required for the interactions endpoint to work.
DISCORD_PUBLIC_KEY=

# Discord BOT TOKEN — used by scripts/registerDiscordCommands.js to register the
# slash commands, and by the cron notification when it posts a message with
# interactive "Generate" buttons (bot-sent messages render components natively).
# Never sent by the request-time interactions handler.
DISCORD_BOT_TOKEN=

# OPTIONAL — numeric ID of the channel where the Tue/Fri cron posts its topic
# notification. When this AND DISCORD_BOT_TOKEN are set, the notification is
# sent via the bot token so the "Generate #N" buttons render (a plain webhook
# can't render interactive buttons). If either is unset, the notification falls
# back to the plain-text DISCORD_WEBHOOK_URL path below.
# To get it: enable Developer Mode in Discord (Settings -> Advanced), then
# right-click the target channel -> Copy Channel ID.
DISCORD_CHANNEL_ID=

# OPTIONAL — comma-separated list of Discord user IDs allowed to run the
# money-spending / state-changing commands (/generate, /publish) and their
# button equivalents. Read-only /topics is not gated. Example:
#   DISCORD_ALLOWED_USER_IDS=123456789012345678,987654321098765432
# If unset/empty, generate & publish are denied for everyone (fail closed).
DISCORD_ALLOWED_USER_IDS=1118493982012481606, 1119698326598713365, 1332308831816126549

# OPTIONAL — force live research regeneration on every /api/topics request,
# bypassing the 24h cache. Leave unset/false in normal/production operation.
# (Per-request alternative during testing: GET /api/topics?fresh=true)
# DISABLE_RESEARCH_CACHE=true

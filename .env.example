# ---------------------------------------------------------------------------
# Melsoft Blog Agent — environment configuration
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Access control: both pages (generator + dashboard) require a Supabase login,
# and the billed /api routes verify that Supabase session server-side. There is
# no separate app password to configure.
# ---------------------------------------------------------------------------

# REQUIRED — Anthropic API key used by research + post generation.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# REQUIRED — Supabase project URL (e.g. https://xxxx.supabase.co).
SUPABASE_URL=your_supabase_project_url_here

# REQUIRED — Supabase SERVICE ROLE key (server-side only; never expose to the
# browser). Used by src/supabaseClient.js for reads/writes and for validating
# the caller's Supabase session token on /api requests.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# OPTIONAL — secret that authenticates the scheduled cron (/api/cron/refresh-topics).
# Vercel injects it as "Authorization: Bearer <CRON_SECRET>" on cron runs.
CRON_SECRET=choose_a_random_string

# OPTIONAL — Discord webhook URL. When set, the Tue/Fri cron posts a notification
# here after it generates fresh topics. Leave unset to disable notifications.
DISCORD_WEBHOOK_URL=

# OPTIONAL — public app URL used in the Discord notification link.
# Defaults to https://melsoft-blog.vercel.app when unset.
APP_URL=

# OPTIONAL — force live research regeneration on every /api/topics request,
# bypassing the 24h cache. Leave unset/false in normal/production operation.
# (Per-request alternative during testing: GET /api/topics?fresh=true)
# DISABLE_RESEARCH_CACHE=true

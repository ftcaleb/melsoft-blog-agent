# ---------------------------------------------------------------------------
# Melsoft Blog Agent — environment configuration
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# ---------------------------------------------------------------------------

# REQUIRED — Anthropic API key used by research + post generation.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# REQUIRED — Supabase project URL (e.g. https://xxxx.supabase.co).
SUPABASE_URL=your_supabase_project_url_here

# REQUIRED — Supabase SERVICE ROLE key (server-side only; never expose to the
# browser). Used by src/supabaseClient.js for reads/writes to the posts table.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# RECOMMENDED FOR PUBLIC DEPLOYS — HTTP Basic Auth gate.
# When BOTH are set, the whole app (pages + /api/* routes) requires this
# username/password, so nobody with the URL can trigger billed API calls.
# Leave both unset for local development to keep the app open.
BASIC_AUTH_USER=choose_a_username
BASIC_AUTH_PASS=choose_a_strong_password

# OPTIONAL — force live research regeneration on every /api/topics request,
# bypassing the 24h cache. Leave unset/false in normal/production operation.
# (Per-request alternative during testing: GET /api/topics?fresh=true)
# DISABLE_RESEARCH_CACHE=true

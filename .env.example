# Anthropic API Key for the blogging agent
ANTHROPIC_API_KEY=ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: force live research regeneration on every /api/topics request,
# bypassing the 24h cache. Leave unset/false in normal/production operation.
# (Per-request alternative during testing: GET /api/topics?fresh=true)
# DISABLE_RESEARCH_CACHE=true
